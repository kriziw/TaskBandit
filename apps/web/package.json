{
  "name": "taskbandit-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:admin": "vite --mode admin --port 5174",
    "dev:client": "vite --mode client --port 5173",
    "build": "tsc --noEmit && vite build",
    "build:admin": "tsc --noEmit && vite build --mode admin",
    "build:client": "tsc --noEmit && vite build --mode client",
    "preview": "vite preview",
    "preview:admin": "vite preview --mode admin --port 4174",
    "preview:client": "vite preview --mode client --port 4173"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.8"
  }
}

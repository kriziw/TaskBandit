generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum HouseholdRole {
  ADMIN
  PARENT
  CHILD
}

enum AuthProvider {
  LOCAL
  OIDC
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ChoreState {
  OPEN
  ASSIGNED
  IN_PROGRESS
  DEFERRED
  PENDING_APPROVAL
  NEEDS_FIXES
  COMPLETED
  OVERDUE
  CANCELLED
}

enum AssignmentStrategyType {
  ROUND_ROBIN
  LEAST_COMPLETED_RECENTLY
  HIGHEST_STREAK
  MANUAL_DEFAULT_ASSIGNEE
  FIXED_ASSIGNEE
}

enum LeaderboardResetMode {
  NEVER
  WEEKLY
  MONTHLY
  QUARTERLY
}

enum AssignmentReasonType {
  ROUND_ROBIN
  LEAST_COMPLETED_RECENTLY
  HIGHEST_STREAK
  MANUAL
  CLAIMED
  STICKY_FOLLOW_UP
  REBALANCED
  FIXED_ASSIGNEE
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  EVERY_X_DAYS
  CUSTOM_WEEKLY
}

enum FollowUpDelayUnit {
  HOURS
  DAYS
}

enum RecurrenceStartStrategy {
  DUE_AT
  COMPLETED_AT
}

enum RecurrenceEndMode {
  NEVER
  AFTER_OCCURRENCES
  ON_DATE
}

enum HolidayExistingMode {
  DEFER
  LEAVE
}

enum NotificationType {
  CHORE_ASSIGNED
  CHORE_TAKEOVER_REQUEST
  CHORE_TAKEOVER_APPROVED
  CHORE_TAKEOVER_DECLINED
  CHORE_TAKEOVER_EXPIRED
  CHORE_SUBMITTED
  CHORE_APPROVED
  CHORE_REJECTED
  CHORE_CANCELLED
  CHORE_DUE_SOON
  CHORE_OVERDUE
  DAILY_SUMMARY
  OVERDUE_PENALTY
  ACHIEVEMENT_UNLOCKED
  MASTERY_EARNED
  REWARD_REDEMPTION_REQUESTED
  REWARD_REDEMPTION_APPROVED
  REWARD_REDEMPTION_REJECTED
  REWARD_CLAIMED_EXCLUSIVE
  REWARD_BOOKING_REMINDER
  HOLIDAY_BLOCK_STARTED
  HOLIDAY_BLOCK_ENDED
  CHORE_CO_COMPLETER_JOINED
}

enum NotificationDevicePlatform {
  ANDROID
  WEB
}

enum NotificationDeviceProvider {
  GENERIC
  FCM
  WEB_PUSH
}

enum NotificationPushDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationEmailDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum ChoreTakeoverRequestStatus {
  PENDING
  APPROVED
  DECLINED
  CANCELLED
}

enum RewardCategory {
  SCREEN_TIME
  ALLOWANCE
  TREAT
  ACTIVITY
  PRIVILEGE
  CUSTOM
}

enum RewardEligibility {
  ALL
  CHILD_ONLY
  ADULT_ONLY
}

enum RewardRedemptionStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum RewardWorkflowType {
  STANDARD
  DAILY_EXCLUSIVE
}

enum CoCompleterRole {
  HELPER
  SUPERVISOR
}

enum JointPointsMode {
  FULL_TO_EACH
  SPLIT_EQUALLY
  PRIMARY_PLUS_BONUS
}

model Tenant {
  id           String               @id @default(uuid()) @db.Uuid
  slug         String               @unique
  displayName  String
  createdAtUtc DateTime             @default(now())
  household    Household?
  members      User[]
  attachments  ChoreAttachment[]
  auditLogs    AuditLog[]
  pointsLedgerEntries PointsLedgerEntry[]
  notifications Notification[]
  notificationPreferences NotificationPreference[]
  notificationDevices NotificationDevice[]
  pushDeliveries NotificationPushDelivery[]
  userAchievements UserAchievement[]
  userTemplateStats UserTemplateStats[]
}

model Household {
  id             String              @id @default(uuid()) @db.Uuid
  tenantId       String              @unique @db.Uuid
  name           String
  createdAtUtc   DateTime            @default(now())
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  settings       HouseholdSettings?
  members        User[]
  choreTemplates ChoreTemplate[]
  choreInstances ChoreInstance[]
  auditLogs      AuditLog[]
  pointsLedgerEntries PointsLedgerEntry[]
  notifications  Notification[]
  choreTakeoverRequests ChoreTakeoverRequest[]
  userAchievements UserAchievement[]
  userTemplateStats UserTemplateStats[]
  rewards        Reward[]
  rewardRedemptions RewardRedemption[]
  holidayBlocks  HouseholdHolidayBlock[]
}

model HouseholdSettings {
  householdId                            String    @id @db.Uuid
  selfSignupEnabled                      Boolean   @default(false)
  onboardingCompleted                   Boolean   @default(false)
  membersCanSeeFullHouseholdChoreDetails Boolean   @default(true)
  enablePushNotifications                Boolean   @default(true)
  enableOverduePenalties                 Boolean   @default(true)
  takeoverPointsDelta                    Int       @default(0)
  localAuthEnabled                       Boolean   @default(true)
  oidcEnabled                            Boolean   @default(false)
  oidcAuthority                          String?
  oidcClientId                           String?
  oidcClientSecret                       String?
  oidcScope                              String    @default("openid profile email")
  smtpEnabled                            Boolean   @default(false)
  smtpHost                               String?
  smtpPort                               Int?
  smtpSecure                             Boolean   @default(false)
  smtpUsername                           String?
  smtpPassword                           String?
  smtpFromEmail                          String?
  smtpFromName                           String?
  enableAchievements                     Boolean   @default(true)
  requireRewardApproval                  Boolean   @default(true)
  leaderboardResetMode                   LeaderboardResetMode @default(NEVER)
  lastLeaderboardResetAt                 DateTime?
  timezone                               String    @default("UTC")
  jointCompletionEnabled                 Boolean   @default(true)
  jointCompletionPointsMode              JointPointsMode @default(SPLIT_EQUALLY)
  jointCompletionHelperBonus             Int       @default(5)
  jointCompletionOpenJoin                Boolean   @default(true)
  onboardingAnswers                      Json?
  household                              Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @db.Uuid
  householdId   String        @db.Uuid
  displayName   String
  role          HouseholdRole
  points        Int           @default(0)
  leaderboardPoints Int       @default(0)
  currentStreak Int           @default(0)
  createdAtUtc  DateTime      @default(now())
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  household     Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  identities    AuthIdentity[]
  auditLogs     AuditLog[]    @relation("AuditActor")
  pointsLedgerEntries PointsLedgerEntry[] @relation("PointsLedgerUser")
  notifications Notification[] @relation("NotificationRecipient")
  notificationPreference NotificationPreference?
  notificationDevices NotificationDevice[]
  takeoverRequestsRequested ChoreTakeoverRequest[] @relation("TakeoverRequester")
  takeoverRequestsReceived ChoreTakeoverRequest[] @relation("TakeoverRequested")
  userAchievements UserAchievement[]
  userTemplateStats UserTemplateStats[]
  redemptionsRequested RewardRedemption[] @relation("RedemptionRequester")
  redemptionsResolved  RewardRedemption[] @relation("RedemptionResolver")
  coCompletions        ChoreInstanceCoCompleter[]

  @@index([householdId])
}

model AuthIdentity {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @db.Uuid
  provider        AuthProvider
  providerSubject String
  email           String?
  passwordHash    String?
  createdAtUtc    DateTime     @default(now())
  updatedAtUtc    DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordResetTokens PasswordResetToken[]

  @@unique([provider, providerSubject])
  @@unique([email], map: "auth_identity_email_unique")
  @@index([userId])
}

model PasswordResetToken {
  id              String       @id @default(uuid()) @db.Uuid
  authIdentityId  String       @db.Uuid
  tokenHash       String       @unique
  expiresAtUtc    DateTime
  usedAtUtc       DateTime?
  createdAtUtc    DateTime     @default(now())
  authIdentity    AuthIdentity @relation(fields: [authIdentityId], references: [id], onDelete: Cascade)

  @@index([authIdentityId, expiresAtUtc])
}

model ChoreTemplate {
  id                 String                       @id @default(uuid()) @db.Uuid
  householdId        String                       @db.Uuid
  defaultLocale      String                       @default("en") @db.VarChar(5)
  groupTitle         String                       @db.VarChar(120)
  groupTitleTranslations Json?
  title              String
  titleTranslations  Json?
  description        String
  descriptionTranslations Json?
  difficulty         Difficulty
  basePoints         Int
  assignmentStrategy AssignmentStrategyType
  fixedAssigneeId    String?
  recurrenceType     RecurrenceType               @default(NONE)
  recurrenceIntervalDays Int?
  recurrenceWeekdays String[]                     @default([])
  requirePhotoProof  Boolean                      @default(false)
  stickyFollowUpAssignee Boolean                  @default(false)
  recurrenceStartStrategy RecurrenceStartStrategy @default(DUE_AT)
  catalogKey         String?
  isOperatorManaged  Boolean                      @default(false)
  masteryDisabled              Boolean            @default(false)
  masteryLevel1Threshold       Int                @default(5)
  masteryLevel2Threshold       Int                @default(10)
  masteryLevel2BonusPercentage Int                @default(10)
  createdAtUtc       DateTime                     @default(now())
  household          Household                    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  checklistItems     ChoreTemplateChecklistItem[]
  dependencies       ChoreTemplateDependency[]
  choreInstances     ChoreInstance[]
  variants           ChoreTemplateVariant[]
  userTemplateStats  UserTemplateStats[]

  @@unique([householdId, catalogKey])
  @@index([householdId])
}

model ChoreTemplateChecklistItem {
  id         String        @id @default(uuid()) @db.Uuid
  templateId String        @db.Uuid
  title      String
  required   Boolean       @default(true)
  sortOrder  Int
  template   ChoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  completions ChoreChecklistCompletion[]
}

model ChoreTemplateDependency {
  id                 String        @id @default(uuid()) @db.Uuid
  templateId         String        @db.Uuid
  followUpTemplateId String        @db.Uuid
  followUpDelayValue Int           @default(1)
  followUpDelayUnit  FollowUpDelayUnit @default(HOURS)
  template           ChoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ChoreInstance {
  id              String        @id @default(uuid()) @db.Uuid
  householdId     String        @db.Uuid
  templateId      String?       @db.Uuid
  cycleId         String?       @db.Uuid
  occurrenceRootId String?      @db.Uuid
  title           String
  subtypeLabel    String?
  requirePhotoProofOverride Boolean?
  state           ChoreState
  assigneeId      String?       @db.Uuid
  dueAtUtc        DateTime
  suppressRecurrence Boolean    @default(false)
  assignmentLocked Boolean      @default(false)
  assignmentReason AssignmentReasonType?
  assignmentStrategyOverride AssignmentStrategyType?
  recurrenceTypeOverride RecurrenceType?
  recurrenceIntervalDaysOverride Int?
  recurrenceWeekdaysOverride String[] @default([])
  recurrenceStartStrategyOverride RecurrenceStartStrategy?
  recurrenceEndModeOverride RecurrenceEndMode?
  recurrenceRemainingOccurrencesOverride Int?
  recurrenceEndsAtUtcOverride DateTime?
  variantId              String?       @db.Uuid
  variant                ChoreTemplateVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  awardedPoints   Int           @default(0)
  overduePenaltyPoints Int      @default(0)
  attachmentCount Int           @default(0)
  completedChecklistItems Int   @default(0)
  createdAtUtc    DateTime      @default(now())
  overduePenaltyAppliedAtUtc DateTime?
  notBeforeAtUtc  DateTime?
  deferredReason  String?
  dependencySourceInstanceId String? @db.Uuid
  submittedAtUtc  DateTime?
  submittedById   String?       @db.Uuid
  submissionNote  String?
  completedAtUtc  DateTime?
  completedById   String?       @db.Uuid
  completedByExternal Boolean   @default(false)
  externalCompleterName String?
  externalCompletionNote String?
  cancelledAtUtc  DateTime?
  reviewedAtUtc   DateTime?
  reviewedById    String?       @db.Uuid
  reviewNote      String?
  household       Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  template        ChoreTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  checklistCompletions ChoreChecklistCompletion[]
  attachments     ChoreAttachment[]
  takeoverRequests ChoreTakeoverRequest[]
  coCompleters    ChoreInstanceCoCompleter[]

  @@index([householdId, cycleId, state], map: "chore_instance_household_cycle_state_idx")
  @@index([householdId, occurrenceRootId, state], map: "chore_instance_household_occurrence_root_state_idx")
  @@index([assigneeId])
}

model ChoreTakeoverRequest {
  id              String                    @id @default(uuid()) @db.Uuid
  householdId     String                    @db.Uuid
  choreInstanceId String                    @db.Uuid
  requesterUserId String                    @db.Uuid
  requestedUserId String                    @db.Uuid
  status          ChoreTakeoverRequestStatus @default(PENDING)
  note            String?
  createdAtUtc    DateTime                  @default(now())
  respondedAtUtc  DateTime?
  household       Household                 @relation(fields: [householdId], references: [id], onDelete: Cascade)
  choreInstance   ChoreInstance             @relation(fields: [choreInstanceId], references: [id], onDelete: Cascade)
  requester       User                      @relation("TakeoverRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  requested       User                      @relation("TakeoverRequested", fields: [requestedUserId], references: [id], onDelete: Cascade)

  @@index([requestedUserId, status, createdAtUtc])
  @@index([choreInstanceId, status, createdAtUtc])
  @@index([householdId, createdAtUtc])
}

model ChoreTemplateVariant {
  id         String        @id @default(uuid()) @db.Uuid
  templateId String        @db.Uuid
  label      String        @db.VarChar(100)
  labelTranslations Json?
  sortOrder  Int           @default(0)
  template   ChoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  instances  ChoreInstance[]
}

model ChoreChecklistCompletion {
  id            String                  @id @default(uuid()) @db.Uuid
  choreInstanceId String                @db.Uuid
  checklistItemId String                @db.Uuid
  completedById String                  @db.Uuid
  createdAtUtc  DateTime                @default(now())
  choreInstance ChoreInstance           @relation(fields: [choreInstanceId], references: [id], onDelete: Cascade)
  checklistItem ChoreTemplateChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  @@unique([choreInstanceId, checklistItemId], map: "chore_checklist_completion_unique")
}

model ChoreInstanceCoCompleter {
  id              String          @id @default(uuid()) @db.Uuid
  choreInstanceId String          @db.Uuid
  userId          String          @db.Uuid
  role            CoCompleterRole
  joinedAtUtc     DateTime        @default(now())
  choreInstance   ChoreInstance   @relation(fields: [choreInstanceId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([choreInstanceId, userId])
}

model ChoreAttachment {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId       String       @db.Uuid
  choreInstanceId String      @db.Uuid
  submittedById String        @db.Uuid
  clientFilename String
  contentType   String?
  storageKey    String?
  sizeBytes     Int           @default(0)
  createdAtUtc  DateTime      @default(now())
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  choreInstance ChoreInstance @relation(fields: [choreInstanceId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  householdId     String   @db.Uuid
  actorUserId     String?  @db.Uuid
  action          String
  entityType      String
  entityId        String?
  summary         String
  createdAtUtc    DateTime @default(now())
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  actor           User?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAtUtc])
  @@index([householdId, createdAtUtc])
}

model PointsLedgerEntry {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  householdId     String   @db.Uuid
  userId          String   @db.Uuid
  choreInstanceId String?  @db.Uuid
  amount          Int
  reason          String
  createdAtUtc    DateTime @default(now())
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user            User      @relation("PointsLedgerUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAtUtc])
  @@index([householdId, createdAtUtc])
  @@index([userId, createdAtUtc])
}

model Notification {
  id                      String                          @id @default(uuid()) @db.Uuid
  tenantId                String                          @db.Uuid
  householdId             String                          @db.Uuid
  recipientUserId         String                          @db.Uuid
  type                    NotificationType
  title                   String
  message                 String
  entityType              String?
  entityId                String?
  isRead                  Boolean                         @default(false)
  emailDeliveryStatus     NotificationEmailDeliveryStatus @default(SKIPPED)
  emailDeliveryError      String?
  emailDeliveredAtUtc     DateTime?
  emailLastAttemptedAtUtc DateTime?
  createdAtUtc            DateTime                        @default(now())
  readAtUtc               DateTime?
  tenant                  Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  household               Household                       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recipient               User                            @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  pushDeliveries          NotificationPushDelivery[]

  @@index([tenantId, recipientUserId, createdAtUtc])
  @@index([householdId, recipientUserId, createdAtUtc])
  @@index([recipientUserId, isRead, createdAtUtc])
  @@index([emailDeliveryStatus, createdAtUtc])
}

model NotificationPreference {
  tenantId                String   @db.Uuid
  userId                  String   @id @db.Uuid
  receiveAssignments      Boolean  @default(true)
  receiveReviewUpdates    Boolean  @default(true)
  receiveDueSoonReminders Boolean  @default(true)
  receiveOverdueAlerts    Boolean  @default(true)
  receiveDailySummary     Boolean  @default(true)
  updatedAtUtc            DateTime @updatedAt
  tenant                  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, updatedAtUtc])
}

model NotificationDevice {
  id                   String                     @id @default(uuid()) @db.Uuid
  tenantId             String                     @db.Uuid
  userId               String                     @db.Uuid
  installationId       String                     @unique
  platform             NotificationDevicePlatform
  provider             NotificationDeviceProvider @default(GENERIC)
  pushToken            String?
  webPushP256dh        String?
  webPushAuth          String?
  deviceName           String?
  appVersion           String?
  locale               String?
  notificationsEnabled Boolean                    @default(true)
  lastSeenAtUtc        DateTime                   @default(now())
  createdAtUtc         DateTime                   @default(now())
  updatedAtUtc         DateTime                   @updatedAt
  tenant               Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushDeliveries       NotificationPushDelivery[]

  @@index([tenantId, notificationsEnabled, updatedAtUtc])
  @@index([userId, notificationsEnabled, updatedAtUtc])
}

model NotificationPushDelivery {
  id                   String                         @id @default(uuid()) @db.Uuid
  tenantId             String                         @db.Uuid
  notificationId       String                         @db.Uuid
  notificationDeviceId String                         @db.Uuid
  status               NotificationPushDeliveryStatus @default(PENDING)
  providerMessageId    String?
  errorMessage         String?
  attemptedAtUtc       DateTime?
  createdAtUtc         DateTime                       @default(now())
  updatedAtUtc         DateTime                       @updatedAt
  tenant               Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notification         Notification                   @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  notificationDevice   NotificationDevice             @relation(fields: [notificationDeviceId], references: [id], onDelete: Cascade)

  @@unique([notificationId, notificationDeviceId], map: "notification_push_delivery_unique")
  @@index([tenantId, status, updatedAtUtc])
  @@index([status, updatedAtUtc])
}

model Achievement {
  key             String            @id
  name            String
  descriptionKey  String
  category        String
  isRepeatable    Boolean           @default(false)
  goal            Int
  bonusPoints     Int               @default(0)
  sortOrder       Int               @default(0)
  createdAtUtc    DateTime          @default(now())
  userAchievements UserAchievement[]
}

model UserAchievement {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @db.Uuid
  householdId    String      @db.Uuid
  userId         String      @db.Uuid
  achievementKey String
  progress       Int         @default(0)
  earnedAt       DateTime?
  timesEarned    Int         @default(0)
  updatedAtUtc   DateTime    @updatedAt
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  household      Household   @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement    Achievement @relation(fields: [achievementKey], references: [key], onDelete: Cascade)

  @@unique([userId, achievementKey])
  @@index([householdId, achievementKey])
  @@index([userId, updatedAtUtc])
}

model UserTemplateStats {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @db.Uuid
  householdId     String        @db.Uuid
  userId          String        @db.Uuid
  templateId      String        @db.Uuid
  completionCount Int           @default(0)
  masteryLevel    Int           @default(0)
  level1AwardedAt DateTime?
  level2AwardedAt DateTime?
  updatedAtUtc    DateTime      @updatedAt
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  household       Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  template        ChoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
  @@index([tenantId, householdId])
  @@index([userId, updatedAtUtc])
}

model Reward {
  id                     String         @id @default(uuid()) @db.Uuid
  householdId            String         @db.Uuid
  catalogKey             String?        // null=custom | "screen_time_30min"=starter | "rwd_*"=operator
  isOperatorManaged      Boolean        @default(false)
  isEnabled              Boolean        @default(false)
  defaultLocale          String         @default("en") @db.VarChar(5)
  title                  String         @db.VarChar(200)
  titleTranslations      Json?
  description            String?        @db.VarChar(2000)
  descriptionTranslations Json?
  category               RewardCategory @default(CUSTOM)
  eligibility            RewardEligibility @default(ALL)
  icon                   String?
  pointCost              Int
  maxRedemptionsPerChild Int?
  cooldownDays           Int?
  workflowType           RewardWorkflowType @default(STANDARD)
  createdAtUtc           DateTime       @default(now())
  household              Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  redemptions            RewardRedemption[]

  @@unique([householdId, catalogKey])
}

model RewardRedemption {
  id             String                 @id @default(uuid()) @db.Uuid
  rewardId       String                 @db.Uuid
  householdId    String                 @db.Uuid
  tenantId       String                 @db.Uuid
  requestedById  String                 @db.Uuid
  status         RewardRedemptionStatus @default(PENDING)
  requestedAtUtc DateTime               @default(now())
  resolvedAtUtc  DateTime?
  resolvedById   String?                @db.Uuid
  adminNote      String?
  pointsDeducted Int
  targetDate     DateTime?              @db.Date
  reward         Reward                 @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  household      Household              @relation(fields: [householdId], references: [id], onDelete: Cascade)
  requestedBy    User                   @relation("RedemptionRequester", fields: [requestedById], references: [id])
  resolvedBy     User?                  @relation("RedemptionResolver", fields: [resolvedById], references: [id])

  @@index([householdId, requestedAtUtc])
  @@index([requestedById, requestedAtUtc])
  @@index([tenantId, requestedAtUtc])
}

model HouseholdHolidayBlock {
  id           String              @id @default(uuid()) @db.Uuid
  householdId  String              @db.Uuid
  name         String
  startDate    DateTime            @db.Date
  endDate      DateTime            @db.Date
  existingMode HolidayExistingMode
  createdBy    String              @db.Uuid
  appliedAt    DateTime?
  createdAt    DateTime            @default(now())
  household    Household           @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, startDate])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HouseholdRole {
  ADMIN
  PARENT
  CHILD
}

enum AuthProvider {
  LOCAL
  OIDC
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ChoreState {
  OPEN
  ASSIGNED
  IN_PROGRESS
  PENDING_APPROVAL
  NEEDS_FIXES
  COMPLETED
  OVERDUE
  CANCELLED
}

enum AssignmentStrategyType {
  ROUND_ROBIN
  LEAST_COMPLETED_RECENTLY
  HIGHEST_STREAK
  MANUAL_DEFAULT_ASSIGNEE
}

enum RecurrenceType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  EVERY_X_DAYS
  CUSTOM_WEEKLY
}

enum FollowUpDelayUnit {
  HOURS
  DAYS
}

enum RecurrenceStartStrategy {
  DUE_AT
  COMPLETED_AT
}

enum RecurrenceEndMode {
  NEVER
  AFTER_OCCURRENCES
  ON_DATE
}

enum NotificationType {
  CHORE_ASSIGNED
  CHORE_TAKEOVER_REQUEST
  CHORE_TAKEOVER_APPROVED
  CHORE_TAKEOVER_DECLINED
  CHORE_SUBMITTED
  CHORE_APPROVED
  CHORE_REJECTED
  CHORE_CANCELLED
  CHORE_DUE_SOON
  CHORE_OVERDUE
  DAILY_SUMMARY
  OVERDUE_PENALTY
}

enum NotificationDevicePlatform {
  ANDROID
  WEB
}

enum NotificationDeviceProvider {
  GENERIC
  FCM
  WEB_PUSH
}

enum NotificationPushDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationEmailDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum ChoreTakeoverRequestStatus {
  PENDING
  APPROVED
  DECLINED
  CANCELLED
}

model Household {
  id             String              @id @default(uuid()) @db.Uuid
  name           String
  createdAtUtc   DateTime            @default(now())
  settings       HouseholdSettings?
  members        User[]
  choreTemplates ChoreTemplate[]
  choreInstances ChoreInstance[]
  auditLogs      AuditLog[]
  pointsLedgerEntries PointsLedgerEntry[]
  notifications  Notification[]
  choreTakeoverRequests ChoreTakeoverRequest[]
}

model HouseholdSettings {
  householdId                            String    @id @db.Uuid
  selfSignupEnabled                      Boolean   @default(false)
  onboardingCompleted                   Boolean   @default(false)
  membersCanSeeFullHouseholdChoreDetails Boolean   @default(true)
  enablePushNotifications                Boolean   @default(true)
  enableOverduePenalties                 Boolean   @default(true)
  takeoverPointsDelta                    Int       @default(0)
  localAuthEnabled                       Boolean   @default(true)
  oidcEnabled                            Boolean   @default(false)
  oidcAuthority                          String?
  oidcClientId                           String?
  oidcClientSecret                       String?
  oidcScope                              String    @default("openid profile email")
  smtpEnabled                            Boolean   @default(false)
  smtpHost                               String?
  smtpPort                               Int?
  smtpSecure                             Boolean   @default(false)
  smtpUsername                           String?
  smtpPassword                           String?
  smtpFromEmail                          String?
  smtpFromName                           String?
  household                              Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(uuid()) @db.Uuid
  householdId   String        @db.Uuid
  displayName   String
  role          HouseholdRole
  points        Int           @default(0)
  currentStreak Int           @default(0)
  createdAtUtc  DateTime      @default(now())
  household     Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  identities    AuthIdentity[]
  auditLogs     AuditLog[]    @relation("AuditActor")
  pointsLedgerEntries PointsLedgerEntry[] @relation("PointsLedgerUser")
  notifications Notification[] @relation("NotificationRecipient")
  notificationPreference NotificationPreference?
  notificationDevices NotificationDevice[]
  takeoverRequestsRequested ChoreTakeoverRequest[] @relation("TakeoverRequester")
  takeoverRequestsReceived ChoreTakeoverRequest[] @relation("TakeoverRequested")
}

model AuthIdentity {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @db.Uuid
  provider        AuthProvider
  providerSubject String
  email           String?
  passwordHash    String?
  createdAtUtc    DateTime     @default(now())
  updatedAtUtc    DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordResetTokens PasswordResetToken[]

  @@unique([provider, providerSubject])
  @@unique([email], map: "auth_identity_email_unique")
}

model PasswordResetToken {
  id              String       @id @default(uuid()) @db.Uuid
  authIdentityId  String       @db.Uuid
  tokenHash       String       @unique
  expiresAtUtc    DateTime
  usedAtUtc       DateTime?
  createdAtUtc    DateTime     @default(now())
  authIdentity    AuthIdentity @relation(fields: [authIdentityId], references: [id], onDelete: Cascade)

  @@index([authIdentityId, expiresAtUtc])
}

model ChoreTemplate {
  id                 String                       @id @default(uuid()) @db.Uuid
  householdId        String                       @db.Uuid
  defaultLocale      String                       @default("en") @db.VarChar(5)
  groupTitle         String                       @db.VarChar(120)
  groupTitleTranslations Json?
  title              String
  titleTranslations  Json?
  description        String
  descriptionTranslations Json?
  difficulty         Difficulty
  basePoints         Int
  assignmentStrategy AssignmentStrategyType
  recurrenceType     RecurrenceType               @default(NONE)
  recurrenceIntervalDays Int?
  recurrenceWeekdays String[]                     @default([])
  requirePhotoProof  Boolean                      @default(false)
  recurrenceStartStrategy RecurrenceStartStrategy @default(DUE_AT)
  createdAtUtc       DateTime                     @default(now())
  household          Household                    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  checklistItems     ChoreTemplateChecklistItem[]
  dependencies       ChoreTemplateDependency[]
  choreInstances     ChoreInstance[]
  variants           ChoreTemplateVariant[]
}

model ChoreTemplateChecklistItem {
  id         String        @id @default(uuid()) @db.Uuid
  templateId String        @db.Uuid
  title      String
  required   Boolean       @default(true)
  sortOrder  Int
  template   ChoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  completions ChoreChecklistCompletion[]
}

model ChoreTemplateDependency {
  id                 String        @id @default(uuid()) @db.Uuid
  templateId         String        @db.Uuid
  followUpTemplateId String        @db.Uuid
  followUpDelayValue Int           @default(1)
  followUpDelayUnit  FollowUpDelayUnit @default(HOURS)
  template           ChoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ChoreInstance {
  id              String        @id @default(uuid()) @db.Uuid
  householdId     String        @db.Uuid
  templateId      String        @db.Uuid
  cycleId         String?       @db.Uuid
  title           String
  subtypeLabel    String?
  requirePhotoProofOverride Boolean?
  state           ChoreState
  assigneeId      String?       @db.Uuid
  dueAtUtc        DateTime
  suppressRecurrence Boolean    @default(false)
  assignmentStrategyOverride AssignmentStrategyType?
  recurrenceTypeOverride RecurrenceType?
  recurrenceIntervalDaysOverride Int?
  recurrenceWeekdaysOverride String[] @default([])
  recurrenceStartStrategyOverride RecurrenceStartStrategy?
  recurrenceEndModeOverride RecurrenceEndMode?
  recurrenceRemainingOccurrencesOverride Int?
  recurrenceEndsAtUtcOverride DateTime?
  variantId              String?       @db.Uuid
  variant                ChoreTemplateVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  awardedPoints   Int           @default(0)
  overduePenaltyPoints Int      @default(0)
  attachmentCount Int           @default(0)
  completedChecklistItems Int   @default(0)
  createdAtUtc    DateTime      @default(now())
  overduePenaltyAppliedAtUtc DateTime?
  submittedAtUtc  DateTime?
  submittedById   String?       @db.Uuid
  submissionNote  String?
  completedAtUtc  DateTime?
  completedById   String?       @db.Uuid
  cancelledAtUtc  DateTime?
  reviewedAtUtc   DateTime?
  reviewedById    String?       @db.Uuid
  reviewNote      String?
  household       Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  template        ChoreTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  checklistCompletions ChoreChecklistCompletion[]
  attachments     ChoreAttachment[]
  takeoverRequests ChoreTakeoverRequest[]

  @@index([householdId, cycleId, state], map: "chore_instance_household_cycle_state_idx")
}

model ChoreTakeoverRequest {
  id              String                    @id @default(uuid()) @db.Uuid
  householdId     String                    @db.Uuid
  choreInstanceId String                    @db.Uuid
  requesterUserId String                    @db.Uuid
  requestedUserId String                    @db.Uuid
  status          ChoreTakeoverRequestStatus @default(PENDING)
  note            String?
  createdAtUtc    DateTime                  @default(now())
  respondedAtUtc  DateTime?
  household       Household                 @relation(fields: [householdId], references: [id], onDelete: Cascade)
  choreInstance   ChoreInstance             @relation(fields: [choreInstanceId], references: [id], onDelete: Cascade)
  requester       User                      @relation("TakeoverRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  requested       User                      @relation("TakeoverRequested", fields: [requestedUserId], references: [id], onDelete: Cascade)

  @@index([requestedUserId, status, createdAtUtc])
  @@index([choreInstanceId, status, createdAtUtc])
  @@index([householdId, createdAtUtc])
}

model ChoreTemplateVariant {
  id         String        @id @default(uuid()) @db.Uuid
  templateId String        @db.Uuid
  label      String        @db.VarChar(100)
  labelTranslations Json?
  sortOrder  Int           @default(0)
  template   ChoreTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  instances  ChoreInstance[]
}

model ChoreChecklistCompletion {
  id            String                  @id @default(uuid()) @db.Uuid
  choreInstanceId String                @db.Uuid
  checklistItemId String                @db.Uuid
  completedById String                  @db.Uuid
  createdAtUtc  DateTime                @default(now())
  choreInstance ChoreInstance           @relation(fields: [choreInstanceId], references: [id], onDelete: Cascade)
  checklistItem ChoreTemplateChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: Cascade)

  @@unique([choreInstanceId, checklistItemId], map: "chore_checklist_completion_unique")
}

model ChoreAttachment {
  id            String        @id @default(uuid()) @db.Uuid
  choreInstanceId String      @db.Uuid
  submittedById String        @db.Uuid
  clientFilename String
  contentType   String?
  storageKey    String?
  createdAtUtc  DateTime      @default(now())
  choreInstance ChoreInstance @relation(fields: [choreInstanceId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String    @id @default(uuid()) @db.Uuid
  householdId     String   @db.Uuid
  actorUserId     String?  @db.Uuid
  action          String
  entityType      String
  entityId        String?
  summary         String
  createdAtUtc    DateTime @default(now())
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  actor           User?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([householdId, createdAtUtc])
}

model PointsLedgerEntry {
  id             String    @id @default(uuid()) @db.Uuid
  householdId     String   @db.Uuid
  userId          String   @db.Uuid
  choreInstanceId String?  @db.Uuid
  amount          Int
  reason          String
  createdAtUtc    DateTime @default(now())
  household       Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user            User      @relation("PointsLedgerUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([householdId, createdAtUtc])
  @@index([userId, createdAtUtc])
}

model Notification {
  id                      String                          @id @default(uuid()) @db.Uuid
  householdId             String                          @db.Uuid
  recipientUserId         String                          @db.Uuid
  type                    NotificationType
  title                   String
  message                 String
  entityType              String?
  entityId                String?
  isRead                  Boolean                         @default(false)
  emailDeliveryStatus     NotificationEmailDeliveryStatus @default(SKIPPED)
  emailDeliveryError      String?
  emailDeliveredAtUtc     DateTime?
  emailLastAttemptedAtUtc DateTime?
  createdAtUtc            DateTime                        @default(now())
  readAtUtc               DateTime?
  household               Household                       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recipient               User                            @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  pushDeliveries          NotificationPushDelivery[]

  @@index([householdId, recipientUserId, createdAtUtc])
  @@index([recipientUserId, isRead, createdAtUtc])
  @@index([emailDeliveryStatus, createdAtUtc])
}

model NotificationPreference {
  userId                  String   @id @db.Uuid
  receiveAssignments      Boolean  @default(true)
  receiveReviewUpdates    Boolean  @default(true)
  receiveDueSoonReminders Boolean  @default(true)
  receiveOverdueAlerts    Boolean  @default(true)
  receiveDailySummary     Boolean  @default(true)
  updatedAtUtc            DateTime @updatedAt
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationDevice {
  id                   String                     @id @default(uuid()) @db.Uuid
  userId               String                     @db.Uuid
  installationId       String                     @unique
  platform             NotificationDevicePlatform
  provider             NotificationDeviceProvider @default(GENERIC)
  pushToken            String?
  webPushP256dh        String?
  webPushAuth          String?
  deviceName           String?
  appVersion           String?
  locale               String?
  notificationsEnabled Boolean                    @default(true)
  lastSeenAtUtc        DateTime                   @default(now())
  createdAtUtc         DateTime                   @default(now())
  updatedAtUtc         DateTime                   @updatedAt
  user                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushDeliveries       NotificationPushDelivery[]

  @@index([userId, notificationsEnabled, updatedAtUtc])
}

model NotificationPushDelivery {
  id                   String                         @id @default(uuid()) @db.Uuid
  notificationId       String                         @db.Uuid
  notificationDeviceId String                         @db.Uuid
  status               NotificationPushDeliveryStatus @default(PENDING)
  providerMessageId    String?
  errorMessage         String?
  attemptedAtUtc       DateTime?
  createdAtUtc         DateTime                       @default(now())
  updatedAtUtc         DateTime                       @updatedAt
  notification         Notification                   @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  notificationDevice   NotificationDevice             @relation(fields: [notificationDeviceId], references: [id], onDelete: Cascade)

  @@unique([notificationId, notificationDeviceId], map: "notification_push_delivery_unique")
  @@index([status, updatedAtUtc])
}

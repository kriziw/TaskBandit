# Core stack
TASKBANDIT_DB_NAME=taskbandit
# Purpose: PostgreSQL database name created and used by TaskBandit.
TASKBANDIT_DB_USER=taskbandit
# Purpose: PostgreSQL username the server uses to connect.
TASKBANDIT_DB_PASSWORD=taskbandit
# Purpose: PostgreSQL password for the TaskBandit database user.
TASKBANDIT_DB_HOST_PORT=5432
# Purpose: Host port that exposes PostgreSQL outside the container stack.
TASKBANDIT_DATA_ROOT=./data
# Purpose: Host folder where persistent TaskBandit and PostgreSQL data is stored.
TASKBANDIT_IMAGE_TAG=latest
# Purpose: Docker image tag used for both the server and web images.
TASKBANDIT_PORT=8080
# Purpose: Host port that exposes the API server for direct access or reverse proxying.
TASKBANDIT_WEB_PORT=4173
# Purpose: Host port that exposes the shared web UI container for direct access or reverse proxying.

# Public URLs
TASKBANDIT_PUBLIC_WEB_BASE_URL=http://localhost:4173
# Purpose: Public browser URL for the client UI; the admin UI is derived as this URL plus /admin.
TASKBANDIT_PUBLIC_API_BASE_URL=http://localhost:8080
# Purpose: Public browser URL for the API that the web clients call.
# For most installs, TaskBandit derives the admin URL, CORS origin, and reverse-proxy mode from the two public URLs above.

# Security and bootstrap
TASKBANDIT_JWT_SECRET=taskbandit-dev-secret-change-me
# Purpose: Secret key used to sign auth tokens and other security-sensitive payloads.
TASKBANDIT_JWT_EXPIRES_IN=7d
# Purpose: Lifetime of issued JWT access tokens.
TASKBANDIT_FORCE_LOCAL_AUTH_ENABLED=false
# Purpose: Force local username/password sign-in on even if household settings disable it.
TASKBANDIT_BOOTSTRAP_SEED_DEMO_DATA=false
# Purpose: Create demo household data on first start for testing and walkthroughs.

# Optional OIDC
# TASKBANDIT_OIDC_ENABLED=false
# Purpose: Enable environment-managed OIDC sign-in as a fallback or primary auth path.
# TASKBANDIT_OIDC_AUTHORITY=
# Purpose: OIDC provider base URL used for discovery and redirects.
# TASKBANDIT_OIDC_CLIENT_ID=
# Purpose: OIDC client ID issued by your identity provider.
# TASKBANDIT_OIDC_CLIENT_SECRET=
# Purpose: OIDC client secret issued by your identity provider.
# TASKBANDIT_OIDC_SCOPE=openid profile email
# Purpose: OIDC scopes requested during sign-in.

# Optional FCM push
TASKBANDIT_FCM_ENABLED=false
# Purpose: Enable Firebase Cloud Messaging delivery for native Android push notifications.
# TASKBANDIT_FCM_SERVICE_ACCOUNT_BASE64=
# Purpose: Base64-encoded Firebase service account JSON used by the server to send FCM pushes.

# Optional Web Push
# TASKBANDIT_WEB_PUSH_PUBLIC_KEY=
# Purpose: Public VAPID key exposed to browsers for Web Push subscription.
# TASKBANDIT_WEB_PUSH_PRIVATE_KEY=
# Purpose: Private VAPID key the server uses to send Web Push notifications.
# TASKBANDIT_WEB_PUSH_SUBJECT=
# Purpose: Contact subject sent with Web Push requests, usually a mailto: or URL.

# Optional legacy overrides
# TASKBANDIT_PUBLIC_ADMIN_BASE_URL=http://localhost:4173/admin
# Purpose: Override the derived public admin URL if you need custom admin routing.
# TASKBANDIT_PUBLIC_CLIENT_BASE_URL=http://localhost:4173
# Purpose: Override the public client URL if you are still using the older config model.
# TASKBANDIT_CORS_ALLOWED_ORIGINS=http://localhost:4173
# Purpose: Explicitly set allowed browser origins if the default derived CORS rule is not enough.
# TASKBANDIT_REVERSE_PROXY_ENABLED=false
# Purpose: Explicitly tell the server it is running behind a reverse proxy.
# These overrides are only for custom routing edge cases and should not be needed in a normal fresh install.

# Optional advanced tuning
# TASKBANDIT_REMINDER_INTERVAL_MS=300000
# Purpose: How often the reminder worker wakes up to process due-soon and overdue checks.
# TASKBANDIT_DUE_SOON_WINDOW_HOURS=6
# Purpose: Number of hours before a chore due time that counts as due soon.
# TASKBANDIT_DAILY_SUMMARY_HOUR_UTC=6
# Purpose: UTC hour when daily summary notifications are generated.
# TASKBANDIT_PUSH_DELIVERY_INTERVAL_MS=60000
# Purpose: How often queued push notifications are processed.
# TASKBANDIT_EMAIL_DELIVERY_INTERVAL_MS=60000
# Purpose: How often queued email fallback notifications are processed.
TASKBANDIT_RUNTIME_LOG_MAX_FILE_SIZE_MB=100
# Purpose: Rotate the persistent TaskBandit runtime log when the active file reaches this size in megabytes.
TASKBANDIT_RUNTIME_LOG_MAX_TOTAL_SIZE_MB=500
# Purpose: Maximum combined size in megabytes kept across the active runtime log and rotated runtime log archives.
TASKBANDIT_DOCKER_LOG_MAX_SIZE=100m
# Purpose: Maximum size of each Docker json-file log before Docker rotates it.
TASKBANDIT_DOCKER_LOG_MAX_FILES=5
# Purpose: Number of Docker json-file log files kept per container, for an approximate 500 MB total cap at the default size.
# TASKBANDIT_FCM_SERVICE_ACCOUNT_JSON=
# Purpose: Raw Firebase service account JSON if you prefer that over the base64 form.
# TASKBANDIT_RUNTIME_LOG_BUFFER_SIZE=1000
# Purpose: Number of recent runtime log entries kept in the in-memory/admin log buffer.
# TASKBANDIT_SERVE_EMBEDDED_WEB=false
# Purpose: Serve the built web UI directly from the API container instead of a separate web container.
# TASKBANDIT_REVERSE_PROXY_PATH_BASE=
# Purpose: Base path added by a reverse proxy when the API is mounted under a subpath.
# TASKBANDIT_STORAGE_ROOT=/var/lib/taskbandit/storage
# Purpose: Absolute container-side path where uploads and runtime data are stored.
# TASKBANDIT_DATA_ROOT_HINT=./data
# Purpose: Helper value shown in backup/export views to remind admins where host data lives.
# TASKBANDIT_COMPOSE_FILE_HINT=./docker-compose.yml
# Purpose: Helper value shown in backup/export views to point to the main Compose file.
# TASKBANDIT_ENV_FILE_HINT=./.env
# Purpose: Helper value shown in backup/export views to point to the active env file.
